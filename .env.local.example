# Copy to .env.local and fill in real values for local dev with `vercel dev`.
# .env.local is gitignored — never commit real secrets.

# --- Client (build-time, embedded in the JS bundle, must be VITE_-prefixed) ---
VITE_TURNSTILE_SITE_KEY="0x4AAAAAADkEVZTQlK0KSYxC"

# --- Server (read by api/contact.js at runtime, NEVER prefix with VITE_) ---
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TURNSTILE_SECRET_KEY="0x4AAAAAA_secret_paired_with_the_site_key_above"
CONTACT_TO="admin@assessproconsultants.com"
CONTACT_FROM="Assesspro Website <noreply@assessproconsultants.com>"
ALLOWED_ORIGIN="http://localhost:3000"
